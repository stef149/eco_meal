{% extends 'base.html.twig' %}

{% block title %}Business List{% endblock %}

{% block body %}
    <div class="container mt-5">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h1 class="h2 text-secondary fw-bold m-0">Businesses</h1>
            <a href="{{ path('app_business_new') }}" class="btn btn-primary d-flex align-items-center gap-2 shadow-sm">
                <span>+ Create new business</span>
            </a>
        </div>

        <div class="card shadow-sm border-0 overflow-hidden">
            <div class="table-responsive">
                <table class="table table-striped table-hover align-middle mb-0">
                    <thead class="table-primary text-uppercase fs-7 fw-semibold text-center">
                    <tr>
                        <th scope="col" style="width: 60px;">ID</th>
                        <th scope="col">Name</th>
                        <th scope="col">City</th>
                        <th scope="col">Street</th>
                        <th scope="col" style="width: 100px;">House No.</th>
                        <th scope="col">Phone Number</th>
                        <th scope="col">Business Type</th>
                        <th scope="col" style="width: 100px;">Edit</th>
                        <th scope="col" style="width: 100px;">Delete</th>
                    </tr>
                    </thead>
                    <tbody class="text-center">
                    {% for business in businesses %}
                        <tr>
                            <td class="fw-bold text-secondary">
                                <a href="{{ path('app_business_view', { id: business.id }) }}" class="text-decoration-none badge bg-light text-dark border p-2">
                                    #{{ business.id }}
                                </a>
                            </td>
                            <td class="fw-semibold text-dark text-start ps-3">{{ business.name }}</td>
                            <td><span class="badge bg-secondary-subtle text-secondary-emphasis rounded-pill px-3">{{ business.city }}</span></td>
                            <td class="text-muted">{{ business.street }}</td>
                            <td>{{ business.houseNumber }}</td>
                            <td class="text-nowrap">{{ business.phoneNumber }}</td>
                            <td>
                            <span class="badge bg-info-subtle text-info-emphasis rounded px-2.5 py-1.5 fw-medium">
                                {{ business.BusinessType.name }}
                            </span>
                            </td>
                            <td>
                                <a href="{{ path('app_business_edit', { id: business.id }) }}" class="btn btn-sm btn-outline-primary px-3 rounded-pill">
                                    Edit
                                </a>
                            </td>
                            <td>
                                <a href="{{ path('app_business_delete', { id: business.id }) }}" class="btn btn-sm btn-outline-danger px-3 rounded-pill">
                                    Delete
                                </a>
                            </td>
                        </tr>
                    {% else %}
                        <tr>
                            <td colspan="9" class="text-muted py-4">No businesses found. Click the button above to add one!</td>
                        </tr>
                    {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    </div>
{% endblock %}
