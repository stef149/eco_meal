{% extends 'base.html.twig' %}

{% block title %}Hello BusinessController!{% endblock %}

{% block body %}
    <style>
        .example-wrapper { margin: 1em auto; max-width: 800px; width: 95%; font: 18px/1.5 sans-serif; }
        .example-wrapper code { background: #F5F5F5; padding: 2px 6px; }
    </style>

    <div class="example-wrapper">
        <a href="{{ path('app_business_new') }}">Create new business</a>
        <table>
            <thead>
            <tr>

                <th>Name</th>
                <th>City</th>
                <th>Street</th>
                <th>House Number</th>
                <th>Phone Number</th>
                <th>BusinessType</th>
            </tr>
            </thead>
            <tbody>

            {% for business in businesses %}
                <tr>
                    <td><a href="{{ path('app_business_view', {
                            id: business.id
                        }) }}">{{ business.id }}</a></td>
                    <td>{{ business.name }}</td>
                    <td>{{ business.city }}</td>
                    <td>{{ business.street }}</td>
                    <td>{{ business.houseNumber }}</td>
                    <td>{{ business.phoneNumber }}</td>
                    <td>{{ business.BusinessType.name }}</td>
                </tr>
            {%  endfor %}
            </tbody>
        </table>
    </div>
{% endblock %}
