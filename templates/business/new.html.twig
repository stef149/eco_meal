{% extends 'base.html.twig' %}

{% block title %}Hello BusinessController!{% endblock %}

{% block body %}
    <style>
        .example-wrapper {
            margin: 1em auto;
            max-width: 800px;
            width: 95%;
            font: 18px/1.5 sans-serif;
        }

        .example-wrapper code {
            background: #F5F5F5;
            padding: 2px 6px;
        }
    </style>

    <div class="example-wrapper">
        {{ form_start(form) }}
             {{ form_row(form.name) }}
             {{ form_row(form.city) }}
             {{ form_row(form.street) }}
             {{ form_row(form.houseNumber) }}
             {{ form_row(form.phoneNumber) }}
             {{ form_row(form.businessType) }}
             {{ form_row(form.submit) }}
        {{ form_end(form) }}

    </div>
{% endblock %}
