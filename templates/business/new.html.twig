{% extends 'base.html.twig' %}

{% block title %}Create New Business{% endblock %}

{# Această linie îi spune lui Symfony să aplice tema Bootstrap 5 pe tot formularul #}
{% form_theme form 'bootstrap_5_layout.html.twig' %}

{% block body %}
    <div class="container mt-5">
        <div class="row justify-content-center">
            <div class="col-md-6 col-lg-5">

                <div class="mb-3">
                    <a href="{{ path('app_business') }}" class="text-decoration-none text-muted small fw-semibold">
                        ← Back to Businesses
                    </a>
                </div>

                <div class="card shadow-sm border-0 rounded-3">
                    <div class="card-body p-4 p-md-5">
                        <h2 class="card-title h4 fw-bold text-dark mb-4 text-center">Create New Business</h2>

                        {{ form_start(form, {'attr': {'class': 'needs-validation'}}) }}

                        <div class="mb-3">
                            {{ form_row(form.name) }}
                        </div>

                        <div class="mb-3">
                            {{ form_row(form.city) }}
                        </div>

                        <div class="mb-3">
                            {{ form_row(form.street) }}
                        </div>

                        <div class="row">
                            <div class="col-6 mb-3">
                                {{ form_row(form.houseNumber) }}
                            </div>
                            <div class="col-6 mb-3">
                                {{ form_row(form.phoneNumber) }}
                            </div>
                        </div>

                        <div class="mb-4">
                            {{ form_row(form.businessType) }}
                        </div>

                        <div class="d-grid gap-2">
                            {{ form_widget(form.submit, {'attr': {'class': 'btn btn-primary btn-lg rounded-pill fw-semibold shadow-sm'}}) }}
                        </div>

                        {{ form_end(form) }}
                    </div>
                </div>

            </div>
        </div>
    </div>
{% endblock %}
