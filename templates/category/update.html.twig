{% extends 'base.html.twig' %}

{% block title %}Edit Category{% endblock %}

{% block body %}
    <div class="container mt-5" style="max-width: 500px;">
        <div class="mb-4">
            <a href="{{ path('app_category') }}" class="text-muted text-decoration-none small fw-medium">
                ← Cancel
            </a>
        </div>

        <div class="card border-0 shadow-sm rounded-3 bg-white p-4 p-md-5">
            <h2 class="h4 fw-bold text-dark mb-2">Edit Category</h2>
            <p class="text-muted small mb-4">Updating category: <strong class="text-dark">#{{ category.id }}</strong></p>

            {{ form_start(form) }}
            <div class="mb-4">
                {{ form_label(form.name, 'Category Name', {'label_attr': {'class': 'form-label fw-semibold text-secondary small'}}) }}
                {{ form_widget(form.name, {'attr': {'class': 'form-control rounded-pill border-light bg-light px-4 py-2.5'}}) }}
                <div class="text-danger small mt-1">
                    {{ form_errors(form.name) }}
                </div>
            </div>

            <div class="d-grid gap-2 pt-2">
                <button type="submit" class="btn btn-primary rounded-pill fw-semibold py-2.5 shadow-sm">
                    Update Category
                </button>
            </div>
            {{ form_end(form) }}
        </div>
    </div>
{% endblock %}
