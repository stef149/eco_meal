{% extends 'base.html.twig' %}

{% block title %}Package Details{% endblock %}

{% block body %}
    <div class="container mt-5" style="max-width: 600px;">
        <div class="mb-4">
            <a href="{{ path('app_package') }}" class="text-muted text-decoration-none small fw-medium">
                ← Back to packages
            </a>
        </div>

        <div class="card border-0 shadow-sm rounded-3 bg-white p-4 p-md-5">
            <div class="text-center mb-4">
                <span class="text-muted small fw-mono d-block mb-1">Package ID: #{{ package.id }}</span>
                <h2 class="h3 fw-bold text-dark mb-2">{{ package.name }}</h2>
                <div class="fs-2 fw-bold text-primary">{{ package.price|number_format(2, ',', '.') }} RON</div>
            </div>

            <div class="bg-light rounded-3 p-4 mb-4">
                <h4 class="h6 fw-bold text-secondary text-uppercase small mb-2">Description</h4>
                <p class="text-dark mb-4">{{ package.description }}</p>

                <div class="row g-3 pt-3 border-top">
                    <div class="col-6">
                        <span class="text-muted d-block small">Category</span>
                        <strong class="text-dark">{{ package.category ? package.category.name : 'N/A' }}</strong>
                    </div>
                    <div class="col-6">
                        <span class="text-muted d-block small">Offered by</span>
                        <strong class="text-dark">{{ package.business ? package.business.name : 'N/A' }}</strong>
                    </div>
                </div>
            </div>

            <div class="d-flex justify-content-center gap-3 border-top pt-4">
                <a href="{{ path('app_package_edit', {'id': package.id}) }}" class="btn btn-outline-secondary rounded-pill px-4 btn-sm fw-medium">
                    Edit Package
                </a>
                <a href="{{ path('app_package_delete', {'id': package.id}) }}" class="btn btn-danger rounded-pill px-4 btn-sm fw-medium">
                    Delete Package
                </a>
            </div>
        </div>
    </div>
{% endblock %}
