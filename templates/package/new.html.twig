{% extends 'base.html.twig' %}

{% block title %}New Package{% endblock %}

{% block body %}
    <div class="container mt-5" style="max-width: 600px;">
        <div class="mb-4">
            <a href="{{ path('app_package') }}" class="text-muted text-decoration-none small fw-medium">
                ← Cancel
            </a>
        </div>

        <div class="card border-0 shadow-sm rounded-3 bg-white p-4 p-md-5">
            <h2 class="h4 fw-bold text-dark mb-4">Create New Package / Menu</h2>

            {{ form_start(form) }}
            <div class="mb-3">
                {{ form_label(form.name, 'Package Name', {'label_attr': {'class': 'form-label fw-semibold text-secondary small'}}) }}
                {{ form_widget(form.name, {'attr': {'class': 'form-control rounded-pill border-light bg-light px-4 py-2.5', 'placeholder': 'e.g. Family Lunch Box'}}) }}
                <div class="text-danger small mt-1">{{ form_errors(form.name) }}</div>
            </div>

            <div class="mb-3">
                {{ form_label(form.description, 'Description', {'label_attr': {'class': 'form-label fw-semibold text-secondary small'}}) }}
                {{ form_widget(form.description, {'attr': {'class': 'form-control rounded-3 border-light bg-light px-4 py-2.5', 'rows': 3, 'placeholder': 'What does this menu include?'}}) }}
                <div class="text-danger small mt-1">{{ form_errors(form.description) }}</div>
            </div>

            <div class="mb-3">
                {{ form_label(form.price, 'Price (RON)', {'label_attr': {'class': 'form-label fw-semibold text-secondary small'}}) }}
                {{ form_widget(form.price, {'attr': {'class': 'form-control rounded-pill border-light bg-light px-4 py-2.5', 'placeholder': '0.00'}}) }}
                <div class="text-danger small mt-1">{{ form_errors(form.price) }}</div>
            </div>

            <div class="mb-3">
                {{ form_label(form.category, 'Menu Category', {'label_attr': {'class': 'form-label fw-semibold text-secondary small'}}) }}
                {{ form_widget(form.category, {'attr': {'class': 'form-select rounded-pill border-light bg-light px-4 py-2.5'}}) }}
                <div class="text-danger small mt-1">{{ form_errors(form.category) }}</div>
            </div>

            <div class="mb-4">
                {{ form_label(form.business, 'Assign to Restaurant / Business', {'label_attr': {'class': 'form-label fw-semibold text-secondary small'}}) }}
                {{ form_widget(form.business, {'attr': {'class': 'form-select rounded-pill border-light bg-light px-4 py-2.5'}}) }}
                <div class="text-danger small mt-1">{{ form_errors(form.business) }}</div>
            </div>

            <div class="d-grid gap-2 pt-2">
                <button type="submit" class="btn btn-primary rounded-pill fw-semibold py-2.5 shadow-sm">
                    Save Package
                </button>
            </div>
            {{ form_end(form) }}
        </div>
    </div>
{% endblock %}
