{% extends 'base.html.twig' %}

{% block title %}Consumers{% endblock %}

{% block body %}
    <div class="container mt-5" style="max-width: 1000px;">
        <div class="d-flex justify-content-between align-items-center mb-5">
            <h2 class="h4 fw-bold text-dark m-0">Consumers</h2>
            <a href="{{ path('app_consumer_new') }}" class="btn btn-primary rounded-pill px-4 shadow-sm fw-semibold">
                + Add New Consumer
            </a>
        </div>

        <div class="row g-4">
            {% for consumer in consumers %}
                <div class="col-md-6 col-lg-4">
                    <div class="card h-100 border-0 shadow-sm rounded-3 bg-white">
                        <div class="card-body p-4 d-flex flex-column justify-content-between">
                            <div>
                                <span class="text-muted small fw-mono d-block mb-1">Consumer #{{ consumer.id }}</span>
                                <h3 class="h5 fw-bold text-dark mb-1">{{ consumer.firstName }} {{ consumer.lastName }}</h3>
                                <p class="text-secondary small mb-2">📞 {{ consumer.phoneNumber }}</p>
                                <span class="badge bg-light text-dark rounded-pill px-2.5 py-1.5 small fw-normal">
                                    📩 {{ consumer.user ? consumer.user.email : 'No linked user' }}
                                </span>
                            </div>

                            <div class="d-flex justify-content-between align-items-center border-top pt-3 mt-4">
                                <div>
                                    <a href="{{ path('app_consumer_view', {'id': consumer.id}) }}" class="text-primary text-decoration-none small fw-medium me-3">View</a>
                                    <a href="{{ path('app_consumer_edit', {'id': consumer.id}) }}" class="text-secondary text-decoration-none small fw-medium">Edit</a>
                                </div>
                                <a href="{{ path('app_consumer_delete', {'id': consumer.id}) }}" class="text-danger text-decoration-none small fw-medium">
                                    Remove
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            {% else %}
                <div class="col-12 text-center py-5">
                    <p class="text-muted fs-5">No consumers registered yet.</p>
                </div>
            {% endfor %}
        </div>
    </div>
{% endblock %}
